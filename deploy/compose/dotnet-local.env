# Environment for VS2026 / VSCode local debugging.
# Run infrastructure only: docker compose -f docker-compose-dotnet.yaml up chromadb ollama ollama-init
# Then set this file as the env source in your VS2026 launch profile or launchSettings.json.
# Goal: debug RAG behavior and .NET parity with stable local dependencies, not model quality.

### Global feature toggles
ENABLE_RERANKER=True
ENABLE_CITATIONS=True
ENABLE_GUARDRAILS=False
ENABLE_AGENTIC_RAG=True
LOGLEVEL=INFO
# LOGLEVEL=DEBUG

### Blazor UI
Settings__UseLocalStorage=false

### Chat generation provider
# Default local baseline: Ollama. Keep this stable while debugging RAG behavior.
APP_LLM_PROVIDER=ollama
APP_LLM_SERVERURL=http://localhost:11434
# APP_LLM_MODELNAME=qwen2.5:3b
APP_LLM_MODELNAME=nemotron-mini:latest
# APP_LLM_MODELNAME=nemotron-3-nano:4b

# OpenAI chat-only debug profile.
# Current .NET OpenAI-compatible provider uses NVIDIA_API_KEY as the bearer token.
# APP_LLM_PROVIDER=openai
# APP_LLM_SERVERURL=https://api.openai.com/v1
# APP_LLM_MODELNAME=gpt-4.1-mini
# NVIDIA_API_KEY=<openai-api-key>

# Azure Foundry OpenAI-compatible chat-only debug profile.
# Use an endpoint that supports /v1/chat/completions.
# Classic Azure OpenAI deployment URLs with api-version need future provider work.
# APP_LLM_PROVIDER=openai
# APP_LLM_SERVERURL=https://<foundry-endpoint>/v1
# APP_LLM_MODELNAME=<model-or-deployment-name>
# NVIDIA_API_KEY=<foundry-key>

# Model profile values. Keep max tokens within the actual model context window.
LLM_TEMPERATURE=0.0
LLM_TOP_P=1.0
LLM_MAX_TOKENS=4096
# LLM HTTP timeout (seconds). Default 600. Raise for slow local models.
APP_LLM_HTTP_TIMEOUT_SECONDS=600

### Embedding provider
# Keep embeddings stable unless intentionally recreating vector collections.
APP_EMBEDDINGS_PROVIDER=ollama
APP_EMBEDDINGS_SERVERURL=http://localhost:11434

# Embedding profile: Snowflake local dev
# Safe pair: snowflake-arctic-embed:22m => APP_EMBEDDINGS_DIM=384.
# APP_EMBEDDINGS_MODELNAME=snowflake-arctic-embed:22m
# APP_EMBEDDINGS_DIM=384

# Embedding profile: Nomic local/dev alternative
# Safe pair: nomic-embed-text => APP_EMBEDDINGS_DIM=768.
# Switching dimensions requires recreating existing Milvus collections.
APP_EMBEDDINGS_MODELNAME=nomic-embed-text
APP_EMBEDDINGS_DIM=768

### RAG server -> reranker service
APP_RERANKER_SERVICE_URL=http://localhost:8083
APP_RERANKER_SERVICE_TIMEOUT_SECONDS=300

### Reranker service -> ranking provider
# Default local baseline: Ollama embeddings as rerank signal, lexical fallback for resilience.
APP_RANKING_PROVIDER=ollama
APP_RANKING_SERVERURL=http://localhost:11434
# APP_RANKING_MODELNAME=snowflake-arctic-embed:22m
# APP_RANKING_MODELNAME=qwen3-embedding:0.6b
APP_RANKING_MODELNAME=nomic-embed-text
APP_RANKING_FALLBACK_PROVIDER=lexical
APP_RANKING_TIMEOUT_SECONDS=20
APP_RANKING_LEXICAL_EMERGENCY_FALLBACK=True
# APP_RANKING_APIKEY=
# APP_RANKING_FALLBACK_MODELNAME=
# APP_RANKING_FALLBACK_SERVERURL=
# APP_RANKING_FALLBACK_APIKEY=

### Vector store and retrieval
# ChromaDB
# .NET uses CHROMA REST, exposed by standalone Chroma on 8000.
APP_VECTORSTORE_URL=http://localhost:8000
APP_VECTORSTORE_NAME=chroma
# Milvus
# .NET uses Milvus REST, exposed by standalone Milvus on 19530.
# APP_VECTORSTORE_URL=http://localhost:19530
# APP_VECTORSTORE_NAME=milvus

COLLECTION_NAME=multimodal_data
VECTOR_DB_TOPK=100
APP_RETRIEVER_TOPK=10
APP_RETRIEVER_SCORETHRESHOLD=0.25

APP_NVINGEST_CHUNKSIZE=512
APP_NVINGEST_CHUNKOVERLAP=150

### Local files and persistence
TEMP_DIR=/tmp/dotnet-rag
APP_OBJECT_STORE_ROOT=/tmp/dotnet-rag-object-store
APP_INGESTOR_CATALOG_PATH=/tmp/dotnet-rag-catalog.json
APP_INGESTION_TASK_STORE_PATH=/tmp/dotnet-rag-ingestion-tasks.json
APP_SUMMARY_STATUS_STORE_PATH=/tmp/dotnet-rag-summary-status.json

### Summarization profile
# Empty model/endpoint means "use the main LLM service".
SUMMARIZER_MODEL=
SUMMARIZER_SERVERURL=
SUMMARIZER_MAX_CHUNK_LENGTH=4096
SUMMARIZER_CHUNK_OVERLAP=200
SUMMARIZER_TEMPERATURE=0.1
SUMMARIZER_MAX_PARALLELIZATION=2

### Optional VLM generation profile
# Ollama local profile:
ENABLE_VLM_INFERENCE=True
VLM_TO_LLM_FALLBACK=True
VLM_MAX_TOTAL_IMAGES=10
APP_VLM_PROVIDER=ollama
APP_VLM_SERVERURL=http://localhost:11434
APP_VLM_MODELNAME=minicpm-v4.6

# OpenAI-compatible VLM profile.
# APP_VLM_PROVIDER=openai
# APP_VLM_SERVERURL=https://<openai-compatible-endpoint>/v1
# APP_VLM_MODELNAME=<vlm-model-or-deployment-name>

# NVIDIA hosted example:
# APP_VLM_PROVIDER=openai
# APP_VLM_SERVERURL=https://integrate.api.nvidia.com/v1
# APP_VLM_MODELNAME=nvidia/nemotron-3-nano-omni-30b-a3b-reasoning

### .NET ingestor parity features
APP_INGESTION_BACKEND=local
# APP_INGESTION_BACKEND=nvingest
# APP_NVINGEST_ENDPOINT=http://localhost:8082/bridge/extract
# APP_INGESTION_ENDPOINT=http://localhost:8082/bridge/extract
# APP_INGESTION_BACKEND=nrl
# APP_NRL_ENDPOINT=http://localhost:8082/bridge/extract
# APP_INGESTION_ENDPOINT=http://localhost:8082/bridge/extract
# APP_INGESTION_API_KEY=

# Optional queued ingestion worker mode.
# APP_INGESTION_EXECUTION_MODE=queued
# APP_INGESTION_JOB_QUEUE_PATH=/tmp/dotnet-rag-ingestion-jobs
# APP_INGESTOR_ROLE=all

### Conversation and output shaping
CONVERSATION_HISTORY=5
MULTITURN_RETRIEVER_SIMPLE=False
FILTER_THINK_TOKENS=True
ENABLE_SOURCE_METADATA=True

### Optional query rewriting profile
# Empty model/endpoint means "use the main LLM service".
ENABLE_QUERYREWRITER=False
APP_QUERYREWRITER_MODELNAME=deepseek-r1:latest
APP_QUERYREWRITER_SERVERURL=http://localhost:11434
APP_QUERYREWRITER_APIKEY=
ENABLE_QUERY_DECOMPOSITION=True
MAX_RECURSION_DEPTH=3

### Optional filter expression generator profile
# Empty model/endpoint means "use the main LLM service".
ENABLE_FILTER_GENERATOR=False
APP_FILTEREXPRESSIONGENERATOR_MODELNAME=
APP_FILTEREXPRESSIONGENERATOR_SERVERURL=
APP_FILTEREXPRESSIONGENERATOR_APIKEY=
APP_FILTEREXPRESSIONGENERATOR_TEMPERATURE=0.0
APP_FILTEREXPRESSIONGENERATOR_TOPP=1.0
APP_FILTEREXPRESSIONGENERATOR_MAXTOKENS=32768

### Optional reflection profile
# Empty model/endpoint means "use the main LLM service".
ENABLE_REFLECTION=True
MAX_REFLECTION_LOOP=2
CONTEXT_RELEVANCE_THRESHOLD=1
RESPONSE_GROUNDEDNESS_THRESHOLD=1
REFLECTION_LLM=deepseek-r1:latest
REFLECTION_LLM_SERVERURL=http://localhost:11434
REFLECTION_LLM_APIKEY=

### Agentic tuning
AGENTIC_PLANNER_MAX_TASKS=5
AGENTIC_PLANNER_MAX_SCOPE_ROUNDS=3
AGENTIC_PLANNER_MAX_ATTEMPTS=3
AGENTIC_TASK_SCOPE_MAX_RETRIES=1
AGENTIC_TASK_ANSWER_MAX_RETRIES=3
AGENTIC_VERIFICATION_MAX_TASKS=3
# AGENTIC_PLANNER_LLM_MODEL=
# AGENTIC_TASK_LLM_MODEL=
# AGENTIC_SEED_GEN_LLM_MODEL=
# AGENTIC_SYNTHESIS_LLM_MODEL=

### Optional tracing
APP_TRACING_ENABLED=False
APP_TRACING_OTLPHTTPENDPOINT=http://localhost:4318/v1/traces
APP_TRACING_OTLPGRPCENDPOINT=grpc://localhost:4317
