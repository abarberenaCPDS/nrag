@page "/settings"
@inject SettingsState SettingsState
@inject RagApiService RagApi
@implements IDisposable

<div style="display:flex;flex-direction:column;height:100%;width:100%;overflow:hidden;">
<div class="settings-page-header">
    <h1>Settings</h1>
    <p>Configure your RAG system parameters and preferences</p>
</div>
<div class="settings-shell" style="flex:1;min-height:0;">
    <nav class="settings-nav" aria-label="Settings sections">
        @foreach (var (name, icon) in _sectionIcons)
        {
            var sectionName = name;
            <button class="settings-nav-item @(_active == sectionName ? "active" : "")"
                    @onclick="() => _active = sectionName">
                <span style="display:inline-flex;align-items:center;gap:8px;">
                    @((MarkupString)icon)
                    @sectionName
                </span>
            </button>
        }
    </nav>

    <div class="settings-content">
        @if (_active == "RAG Configuration")
        {
            <RagConfigSection />
        }
        else if (_active == "Feature Toggles")
        {
            <FeatureTogglesSection />
        }
        else if (_active == "Model Configuration")
        {
            <ModelsSection />
        }
        else if (_active == "Endpoint Configuration")
        {
            <EndpointsSection />
        }
        else if (_active == "Other Settings")
        {
            <AdvancedSection />
        }
    </div>
</div>
</div>

@code {
    private readonly (string, string)[] _sectionIcons =
    [
        ("RAG Configuration",
         """<svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true"><path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"/><polyline points="14 2 14 8 20 8"/><line x1="16" y1="13" x2="8" y2="13"/><line x1="16" y1="17" x2="8" y2="17"/><polyline points="10 9 9 9 8 9"/></svg>"""),
        ("Feature Toggles",
         """<svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true"><rect x="3" y="3" width="7" height="7"/><rect x="14" y="3" width="7" height="7"/><rect x="14" y="14" width="7" height="7"/><rect x="3" y="14" width="7" height="7"/></svg>"""),
        ("Model Configuration",
         """<svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true"><rect x="2" y="3" width="20" height="14" rx="2" ry="2"/><line x1="8" y1="21" x2="16" y2="21"/><line x1="12" y1="17" x2="12" y2="21"/></svg>"""),
        ("Endpoint Configuration",
         """<svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true"><circle cx="12" cy="12" r="2"/><path d="M16.24 7.76a6 6 0 0 1 0 8.49m-8.48-.01a6 6 0 0 1 0-8.49m11.31-2.82a10 10 0 0 1 0 14.14m-14.14 0a10 10 0 0 1 0-14.14"/></svg>"""),
        ("Other Settings",
         """<svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true"><circle cx="12" cy="12" r="3"/><path d="M19.4 15a1.65 1.65 0 0 0 .33 1.82l.06.06a2 2 0 0 1-2.83 2.83l-.06-.06a1.65 1.65 0 0 0-1.82-.33 1.65 1.65 0 0 0-1 1.51V21a2 2 0 0 1-4 0v-.09A1.65 1.65 0 0 0 9 19.4a1.65 1.65 0 0 0-1.82.33l-.06.06a2 2 0 0 1-2.83-2.83l.06-.06A1.65 1.65 0 0 0 4.68 15a1.65 1.65 0 0 0-1.51-1H3a2 2 0 0 1 0-4h.09A1.65 1.65 0 0 0 4.6 9a1.65 1.65 0 0 0-.33-1.82l-.06-.06a2 2 0 0 1 2.83-2.83l.06.06A1.65 1.65 0 0 0 9 4.68a1.65 1.65 0 0 0 1-1.51V3a2 2 0 0 1 4 0v.09a1.65 1.65 0 0 0 1 1.51 1.65 1.65 0 0 0 1.82-.33l.06-.06a2 2 0 0 1 2.83 2.83l-.06.06A1.65 1.65 0 0 0 19.4 9a1.65 1.65 0 0 0 1.51 1H21a2 2 0 0 1 0 4h-.09a1.65 1.65 0 0 0-1.51 1z"/></svg>"""),
    ];
    private string _active = "RAG Configuration";

    protected override void OnInitialized() => SettingsState.OnChange += StateHasChanged;

    protected override async Task OnInitializedAsync()
    {
        var config = await RagApi.GetConfigurationAsync();
        if (config is not null)
        {
            SettingsState.ApplyServerDefaults(config);
        }
    }

    public void Dispose() => SettingsState.OnChange -= StateHasChanged;
}
