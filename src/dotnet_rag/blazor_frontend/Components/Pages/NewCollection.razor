@page "/collections/new"
@inject IngestorApiService IngestorApi
@inject NotificationState NotifState
@inject NavigationManager Nav

<div style="height:100%;width:100%;overflow-y:auto;">
<div style="max-width:800px;margin:0 auto;padding:32px;">
    <h1 style="font-size:20px;font-weight:600;margin-bottom:8px;">Create New Collection</h1>
    <p class="text-muted" style="font-size:13px;margin-bottom:28px;">Upload source files and define metadata schema for this collection.</p>

    <!-- Stepper -->
    <div class="stepper">
        @for (int i = 0; i < _steps.Length; i++)
        {
            var idx = i;
            var stepClass = idx < _step ? "done" : idx == _step ? "active" : "";
            var stepNum = idx < _step ? "✓" : (idx + 1).ToString();
            <div class="step @stepClass">
                <div class="step-num">@stepNum</div>
                <span class="step-label">@_steps[idx]</span>
            </div>
        }
    </div>

    <!-- Step 0: Upload files -->
    @if (_step == 0)
    {
        <FileUploadZone OnFilesAdded="HandleFilesAdded" />
        <div class="file-list">
            @foreach (var (f, idx2) in _form.Files.Select((f, i) => (f, i)))
            {
                var capturedIdx = idx2;
                <div class="file-item">
                    <span class="file-name">@f.Name</span>
                    <span class="file-size">@FormatSize(f.Size)</span>
                    <button class="file-remove" @onclick="() => _form.Files.RemoveAt(capturedIdx)" aria-label="Remove file">✕</button>
                </div>
            }
        </div>
        <div style="margin-top:20px;display:flex;justify-content:space-between;align-items:center;">
            <span style="font-size:12px;color:var(--text-muted);">Files are optional — you can add them later.</span>
            <button class="send-btn" style="width:auto;padding:8px 20px;border-radius:6px;font-size:13px;font-weight:500;"
                    @onclick="() => _step++">
                Next: Metadata schema
            </button>
        </div>
    }

    <!-- Step 1: Metadata schema -->
    @if (_step == 1)
    {
        <MetadataSchemaEditor Schema="_form.Schema" SchemaChanged="s => _form.Schema = s" />
        <div style="margin-top:20px;display:flex;justify-content:space-between;">
            <button style="background:transparent;border:1px solid var(--border);border-radius:6px;padding:8px 16px;color:var(--text-muted);cursor:pointer;font-size:13px;"
                    @onclick="() => _step--">Back</button>
            <button class="send-btn" style="width:auto;padding:8px 20px;border-radius:6px;font-size:13px;font-weight:500;"
                    @onclick="() => _step++">
                Next: Collection info
            </button>
        </div>
    }

    <!-- Step 2: Catalog info -->
    @if (_step == 2)
    {
        <div style="display:flex;flex-direction:column;gap:14px;">
            <!-- Collection name with validation -->
            <div>
                <div style="font-size:12px;color:var(--text-muted);margin-bottom:4px;">Collection name *</div>
                <input type="text" value="@_form.CollectionName"
                       @oninput="HandleCollectionNameInput"
                       placeholder="my_collection"
                       style="width:100%;background:var(--ground);border:1px solid @(_nameError.Length > 0 ? "var(--error)" : "var(--border)");border-radius:6px;padding:6px 10px;color:var(--text);font-size:13px;outline:none;box-sizing:border-box;" />
                @if (_nameError.Length > 0)
                {
                    <div style="color:var(--error);font-size:12px;margin-top:4px;">@_nameError</div>
                }
            </div>

            <LabeledInput Label="Description" Value="@_form.Description" ValueChanged="v => _form.Description = v" />

            <!-- Tags chip input -->
            <div>
                <div style="font-size:12px;color:var(--text-muted);margin-bottom:4px;">Tags</div>
                @if (_form.Tags.Count > 0)
                {
                    <div style="display:flex;flex-wrap:wrap;gap:4px;margin-bottom:6px;">
                        @foreach (var tag in _form.Tags.ToList())
                        {
                            var t = tag;
                            <span style="display:inline-flex;align-items:center;gap:4px;background:var(--ground);border:1px solid var(--border);border-radius:4px;padding:2px 8px;font-size:12px;cursor:pointer;"
                                  @onclick="() => _form.Tags.Remove(t)">
                                @t <span style="color:var(--text-muted);" aria-hidden="true">×</span>
                            </span>
                        }
                    </div>
                }
                <div style="display:flex;gap:6px;">
                    <input type="text" @bind="_newTag" @bind:event="oninput"
                           @onkeydown="HandleTagKeyDown"
                           placeholder="Add tag…"
                           style="flex:1;background:var(--ground);border:1px solid var(--border);border-radius:6px;padding:6px 10px;color:var(--text);font-size:13px;outline:none;" />
                    <button @onclick="AddTag"
                            style="background:var(--ground);border:1px solid var(--border);border-radius:6px;padding:6px 12px;cursor:pointer;color:var(--text);font-size:13px;">
                        Add
                    </button>
                </div>
            </div>

            <LabeledInput Label="Owner" Value="@_form.Owner" ValueChanged="v => _form.Owner = v" />

            <!-- Business Domain select -->
            <div>
                <div style="font-size:12px;color:var(--text-muted);margin-bottom:4px;">Business Domain</div>
                <select @bind="_form.BusinessDomain"
                        style="width:100%;background:var(--ground);border:1px solid var(--border);border-radius:6px;padding:6px 10px;color:var(--text);font-size:13px;outline:none;">
                    <option value="">Select domain…</option>
                    <option value="Engineering">Engineering</option>
                    <option value="Finance">Finance</option>
                    <option value="Legal">Legal</option>
                    <option value="Marketing">Marketing</option>
                    <option value="Operations">Operations</option>
                    <option value="Product">Product</option>
                    <option value="Sales">Sales</option>
                    <option value="Support">Support</option>
                    <option value="Other">Other</option>
                </select>
            </div>

            <!-- Status select -->
            <div>
                <div style="font-size:12px;color:var(--text-muted);margin-bottom:4px;">Status</div>
                <select @bind="_form.Status"
                        style="width:100%;background:var(--ground);border:1px solid var(--border);border-radius:6px;padding:6px 10px;color:var(--text);font-size:13px;outline:none;">
                    <option value="Active">Active</option>
                    <option value="Archived">Archived</option>
                    <option value="Deprecated">Deprecated</option>
                </select>
            </div>

            <div style="display:flex;align-items:center;gap:8px;font-size:13px;">
                <input type="checkbox" id="gen-summary" @bind="_form.GenerateSummary" style="accent-color:var(--accent);" />
                <label for="gen-summary">Generate document summaries</label>
            </div>
        </div>
        <div style="margin-top:20px;display:flex;justify-content:space-between;align-items:center;">
            <button style="background:transparent;border:1px solid var(--border);border-radius:6px;padding:8px 16px;color:var(--text-muted);cursor:pointer;font-size:13px;"
                    @onclick="() => _step--">Back</button>
            <div style="display:flex;gap:8px;">
                <a href="/"
                   style="background:transparent;border:1px solid var(--border);border-radius:6px;padding:8px 16px;color:var(--text-muted);cursor:pointer;font-size:13px;text-decoration:none;display:inline-flex;align-items:center;">
                    Cancel
                </a>
                <button class="send-btn" style="width:auto;padding:8px 20px;border-radius:6px;font-size:13px;font-weight:500;"
                        disabled="@(string.IsNullOrWhiteSpace(_form.CollectionName) || _nameError.Length > 0)"
                        @onclick="Submit">
                    Create Collection
                </button>
            </div>
        </div>
    }

    <!-- Step 3: creating -->
    @if (_step == 3)
    {
        <div style="text-align:center;padding:40px 0;">
            @if (_uploadError is not null)
            {
                <p style="color:var(--error);font-size:14px;">@_uploadError</p>
                <button style="margin-top:16px;background:transparent;border:1px solid var(--border);border-radius:6px;padding:8px 16px;color:var(--text);cursor:pointer;"
                        @onclick="ResetForm">Start over</button>
            }
            else
            {
                <div class="typing-indicator" style="justify-content:center;"><span></span><span></span><span></span></div>
                <p class="text-muted" style="margin-top:12px;font-size:13px;">Creating collection…</p>
            }
        </div>
    }
</div>
</div>

@code {
    private readonly string[] _steps = ["Upload files", "Metadata schema", "Collection info", "Processing"];
    private int _step;
    private readonly NewCollectionForm _form = new();
    private string? _uploadError;
    private string _nameError = "";
    private string _newTag = "";

    private static readonly System.Text.RegularExpressions.Regex NameRegex =
        new(@"^[_a-zA-Z][_a-zA-Z0-9]*$", System.Text.RegularExpressions.RegexOptions.Compiled);

    private void HandleCollectionNameInput(ChangeEventArgs e)
    {
        var val = (e.Value?.ToString() ?? "").Replace(' ', '_');
        _form.CollectionName = val;
        _nameError = !string.IsNullOrEmpty(val) && !NameRegex.IsMatch(val)
            ? "Name must start with a letter or underscore and contain only letters, numbers, and underscores."
            : "";
    }

    private void AddTag()
    {
        var tag = _newTag.Trim();
        if (string.IsNullOrEmpty(tag) || _form.Tags.Contains(tag)) return;
        _form.Tags.Add(tag);
        _newTag = "";
    }

    private void HandleTagKeyDown(KeyboardEventArgs e)
    {
        if (e.Key == "Enter") AddTag();
    }

    private void HandleFilesAdded(List<UploadFile> files) => _form.Files.AddRange(files);

    private void ResetForm()
    {
        _step = 0;
        _uploadError = null;
    }

    private async Task Submit()
    {
        _step = 3;
        StateHasChanged();

        // Step 1: create the collection (schema + catalog metadata)
        var created = await IngestorApi.CreateCollectionAsync(new CreateCollectionRequest
        {
            CollectionName = _form.CollectionName,
            Description = _form.Description,
            Tags = _form.Tags,
            Owner = _form.Owner,
            BusinessDomain = _form.BusinessDomain,
            Status = _form.Status,
            MetadataSchema = _form.Schema
        });

        if (!created)
        {
            _uploadError = "Failed to create collection. Check the ingestor server is running.";
            return;
        }

        // Step 2: upload files (optional)
        if (_form.Files.Count == 0)
        {
            NotifState.AddToast($"Collection '{_form.CollectionName}' created.", ToastSeverity.Success);
            Nav.NavigateTo("/");
            return;
        }

        var result = await IngestorApi.UploadDocumentsAsync(
            _form.CollectionName, _form.Files, _form.Schema,
            _form.Description, _form.Tags, _form.GenerateSummary,
            owner: string.IsNullOrEmpty(_form.Owner) ? null : _form.Owner,
            businessDomain: string.IsNullOrEmpty(_form.BusinessDomain) ? null : _form.BusinessDomain,
            status: _form.Status);

        if (result?.TaskId is null)
        {
            _uploadError = "Collection created but document upload failed. Check the ingestor server is running.";
            return;
        }

        // Task started — hand off to the notification bell and navigate away
        NotifState.AddTask(result.TaskId, _form.CollectionName);
        Nav.NavigateTo("/");
    }

    private static string FormatSize(long bytes)
    {
        if (bytes < 1024) return $"{bytes} B";
        if (bytes < 1024 * 1024) return $"{bytes / 1024.0:F1} KB";
        return $"{bytes / (1024.0 * 1024):F1} MB";
    }

}
