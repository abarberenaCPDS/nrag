@inject SettingsState S

<div class="settings-section">
    <h2>Models</h2>

    <SettingsText Label="LLM Model" Description="Language model for answer generation." @bind-Value="S.LlmModelName" />
    <SettingsText Label="Embedding Model" Description="Model for vectorizing documents and queries." @bind-Value="S.EmbeddingModelName" />
    <SettingsText Label="Reranker Model" Description="Model for reranking retrieved chunks." @bind-Value="S.RankingModelName" />
    <SettingsText Label="VLM Model" Description="Vision language model for multimodal queries." @bind-Value="S.VlmModelName" />
    <SettingsText Label="Query Rewriter Model" Description="Model used for query rewriting and query decomposition." @bind-Value="S.QueryRewriterModelName" />
    <SettingsText Label="Filter Generator Model" Description="Model used to generate metadata filter expressions." @bind-Value="S.FilterExpressionGeneratorModelName" />
    <SettingsText Label="Reflection Model" Description="Model used for context relevance and groundedness checks." @bind-Value="S.ReflectionModelName" />
</div>
