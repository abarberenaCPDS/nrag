@inherits LayoutComponentBase
@using DotnetRag.Blazor.Components.Shared
@inject IJSRuntime JS
@inject SettingsState Settings
@inject RagApiService RagApi
@inject NotificationState NotifState
@implements IDisposable

<MudThemeProvider IsDarkMode="@Settings.IsDarkMode" Theme="_nvidiaTheme" />
<MudPopoverProvider />
<MudDialogProvider />
<MudSnackbarProvider />

<div class="app-shell">
    <nav class="app-nav">
        <a href="/" class="nav-brand">
            <!-- NVIDIA wordmark simplified -->
            <svg width="20" height="20" viewBox="0 0 20 20" fill="none" aria-hidden="true">
                <rect width="20" height="20" rx="3" fill="#76B900"/>
                <path d="M4 14V8.5L8 6l4 2.5V14" stroke="#000" stroke-width="1.5" stroke-linejoin="round"/>
                <path d="M8 6v8M4 11h8" stroke="#000" stroke-width="1.5"/>
            </svg>
            RAG <span class="brand-accent">Blueprint</span>
        </a>
        <div class="nav-links">
            <NavLink href="/" class="nav-link-btn" Match="NavLinkMatch.All">
                <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true" style="margin-right:4px;">
                    <path d="M21 15a2 2 0 0 1-2 2H7l-4 4V5a2 2 0 0 1 2-2h14a2 2 0 0 1 2 2z"/>
                </svg>
                Chat
            </NavLink>
            <NavLink href="/collections/new" class="nav-link-btn">
                <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true" style="margin-right:4px;">
                    <path d="M22 19a2 2 0 0 1-2 2H4a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h5l2 3h9a2 2 0 0 1 2 2z"/>
                    <line x1="12" y1="11" x2="12" y2="17"/><line x1="9" y1="14" x2="15" y2="14"/>
                </svg>
                New Collection
            </NavLink>
            <NavLink href="/settings" class="nav-link-btn">
                <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true" style="margin-right:4px;">
                    <circle cx="12" cy="12" r="3"/>
                    <path d="M19.4 15a1.65 1.65 0 0 0 .33 1.82l.06.06a2 2 0 0 1-2.83 2.83l-.06-.06a1.65 1.65 0 0 0-1.82-.33 1.65 1.65 0 0 0-1 1.51V21a2 2 0 0 1-4 0v-.09A1.65 1.65 0 0 0 9 19.4a1.65 1.65 0 0 0-1.82.33l-.06.06a2 2 0 0 1-2.83-2.83l.06-.06A1.65 1.65 0 0 0 4.68 15a1.65 1.65 0 0 0-1.51-1H3a2 2 0 0 1 0-4h.09A1.65 1.65 0 0 0 4.6 9a1.65 1.65 0 0 0-.33-1.82l-.06-.06a2 2 0 0 1 2.83-2.83l.06.06A1.65 1.65 0 0 0 9 4.68a1.65 1.65 0 0 0 1-1.51V3a2 2 0 0 1 4 0v.09a1.65 1.65 0 0 0 1 1.51 1.65 1.65 0 0 0 1.82-.33l.06-.06a2 2 0 0 1 2.83 2.83l-.06.06A1.65 1.65 0 0 0 19.4 9a1.65 1.65 0 0 0 1.51 1H21a2 2 0 0 1 0 4h-.09a1.65 1.65 0 0 0-1.51 1z"/>
                </svg>
                Settings
            </NavLink>
        </div>
        <div class="nav-spacer"></div>
        <NotificationBell />
        <HealthBadge />
    </nav>

    <div class="app-body">
        @Body
    </div>
</div>

<ToastContainer />

<div id="blazor-error-ui" data-nosnippet>
    An unhandled error has occurred.
    <a href="." class="reload">Reload</a>
</div>

@code {
    private readonly MudTheme _nvidiaTheme = new()
    {
        PaletteLight = new PaletteLight
        {
            Primary = "#76B900",
            Background = "#0D1117",
            Surface = "#161B22",
            TextPrimary = "#E6EDF3",
            TextSecondary = "#8B949E",
            AppbarBackground = "#161B22",
            DrawerBackground = "#161B22",
        },
        PaletteDark = new PaletteDark
        {
            Primary = "#76B900",
            Background = "#0D1117",
            Surface = "#161B22",
            TextPrimary = "#E6EDF3",
            TextSecondary = "#8B949E",
            AppbarBackground = "#161B22",
            DrawerBackground = "#161B22",
        }
    };

    private PeriodicTimer? _healthTimer;

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (!firstRender) return;

        // Restore user settings from localStorage (server defaults applied later by Chat.razor)
        try
        {
            var json = await JS.InvokeAsync<string?>("ragApp.loadSettings");
            if (json is not null) Settings.ApplyJson(json);
        }
        catch { }

        Settings.OnChange += OnSettingsChanged;
        _ = PollHealthAsync();
    }

    private async void OnSettingsChanged()
    {
        if (Settings.UseLocalStorage)
        {
            try { await JS.InvokeVoidAsync("ragApp.saveSettings", Settings.ToJson()); }
            catch { }
        }
        await InvokeAsync(StateHasChanged);
    }

    private async Task PollHealthAsync()
    {
        _healthTimer = new PeriodicTimer(TimeSpan.FromSeconds(30));
        try
        {
            while (await _healthTimer.WaitForNextTickAsync())
            {
                var health = await RagApi.GetHealthAsync();
                if (health is not null)
                    await InvokeAsync(() => NotifState.SetHealth(health));
            }
        }
        catch (OperationCanceledException) { }
        catch { }
    }

    public void Dispose()
    {
        Settings.OnChange -= OnSettingsChanged;
        _healthTimer?.Dispose();
    }
}
