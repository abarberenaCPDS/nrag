# Environment for full Docker deployment (all services in containers).
# Used by docker-compose-dotnet.yaml.
# For VS2026 local debugging against Docker infrastructure, use dotnet-local.env instead.

APP_LLM_PROVIDER=ollama
APP_LLM_SERVERURL=http://ollama:11434
APP_LLM_MODELNAME=qwen2.5:3b
LLM_TEMPERATURE=0.0
LLM_TOP_P=1.0
LLM_MAX_TOKENS=4096

APP_EMBEDDINGS_SERVERURL=http://ollama:11434
APP_EMBEDDINGS_MODELNAME=nomic-embed-text

APP_RERANKER_SERVICE_URL=http://dotnet-reranker-service:8083
APP_RERANKER_SERVICE_TIMEOUT_SECONDS=10

APP_RANKING_PROVIDER=ollama
APP_RANKING_SERVERURL=http://ollama:11434
APP_RANKING_MODELNAME=nomic-embed-text
APP_RANKING_FALLBACK_PROVIDER=lexical
APP_RANKING_TIMEOUT_SECONDS=20

APP_VECTORSTORE_URL=http://chromadb:8000
APP_VECTORSTORE_NAME=chroma
COLLECTION_NAME=multimodal_data

APP_NVINGEST_CHUNKSIZE=512
APP_NVINGEST_CHUNKOVERLAP=150

CONVERSATION_HISTORY=5
MULTITURN_RETRIEVER_SIMPLE=False
FILTER_THINK_TOKENS=True
ENABLE_SOURCE_METADATA=True

ENABLE_RERANKER=True
ENABLE_CITATIONS=True
ENABLE_GUARDRAILS=False
ENABLE_QUERYREWRITER=False

LOGLEVEL=INFO
TEMP_DIR=/tmp-data
