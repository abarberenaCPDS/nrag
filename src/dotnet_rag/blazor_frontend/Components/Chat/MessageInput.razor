@inject IJSRuntime JS
@inject CollectionsState ColState
@inject SettingsState Settings
@inject ChatState ChatSt
@inject IDialogService DialogService
@implements IDisposable

<div class="chat-input-bar">
    <!-- Collection chips + agentic mode row (mirrors React MessageInput top row) -->
    <div class="input-meta-row">
        @if (ColState.SelectedCollectionNames.Count > 0)
        {
            <div class="collection-chips-row" style="flex:1;padding:0;">
                <span class="collection-chips-label">
                    <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true" style="vertical-align:-1px;margin-right:3px;">
                        <path d="M22 19a2 2 0 0 1-2 2H4a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h5l2 3h9a2 2 0 0 1 2 2z"/>
                    </svg>
                    Collections:
                </span>
                @foreach (var name in ColState.SelectedCollectionNames.ToList())
                {
                    var capName = name;
                    <button class="collection-chip" @onclick="() => ColState.ToggleSelection(capName)"
                            title="Remove @capName" aria-label="Remove collection @capName">
                        @capName
                        <span class="chip-x" aria-hidden="true">×</span>
                    </button>
                }
            </div>
        }
        <AgenticModeSelector />
        @if (ChatSt.Messages.Count > 0)
        {
            <button style="background:none;border:none;color:var(--text-muted);font-size:12px;cursor:pointer;white-space:nowrap;margin-left:auto;"
                    @onclick="ConfirmClearChat" title="Clear chat history">
                Clear chat
            </button>
        }
    </div>

    @if (ColState.SelectedCollectionNames.Count > 1)
    {
        <div class="warning-banner-inline">
            Filters not available with more than one collection selected
        </div>
    }

    @if (_attachedImages.Count > 0)
    {
        <div style="display:flex;gap:6px;flex-wrap:wrap;margin-bottom:8px;">
            @foreach (var (img, i) in _attachedImages.Select((x, i) => (x, i)))
            {
                var idx = i;
                <div style="position:relative;">
                    <img src="@img.DataUri" alt="Attached image preview"
                         style="width:60px;height:60px;object-fit:cover;border-radius:4px;border:1px solid var(--border);" />
                    <button style="position:absolute;top:-4px;right:-4px;width:16px;height:16px;border-radius:50%;background:var(--error);border:none;cursor:pointer;color:#fff;font-size:11px;display:flex;align-items:center;justify-content:center;"
                            @onclick="() => RemoveImage(idx)" aria-label="Remove image">×</button>
                </div>
            }
        </div>
    }

    <div class="chat-input-wrap @(_isDragOver ? "drag-over" : "")"
         @ondragover="HandleDragOver" @ondragover:preventDefault="true"
         @ondragleave="HandleDragLeave"
         @ondrop="HandleDrop" @ondrop:preventDefault="true">

        <textarea class="chat-textarea"
                  rows="1"
                  placeholder="Ask a question about your documents…"
                  @bind="_text"
                  @bind:event="oninput"
                  @onkeydown="HandleKeyDown"
                  disabled="@Disabled"
                  aria-label="Message input"
                  id="chat-textarea"></textarea>

        <label style="cursor:pointer;color:var(--text-muted);display:flex;align-items:center;padding:4px;" title="Attach image (PNG, JPEG, WebP)">
            <InputFile OnChange="HandleImageAttach" accept="image/png,image/jpeg,image/gif,image/webp"
                       style="display:none;" />
            <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true">
                <rect x="3" y="3" width="18" height="18" rx="2"/>
                <circle cx="8.5" cy="8.5" r="1.5"/>
                <polyline points="21 15 16 10 5 21"/>
            </svg>
        </label>

        @if (Disabled)
        {
            <button class="send-btn" style="background:var(--error);" @onclick="HandleStop" aria-label="Stop generation" title="Stop">
                <svg width="14" height="14" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
                    <rect x="4" y="4" width="16" height="16" rx="2"/>
                </svg>
            </button>
        }
        else
        {
            <button class="send-btn" @onclick="Submit"
                    disabled="@(Disabled || string.IsNullOrWhiteSpace(_text))"
                    aria-label="Send message" title="Send (Ctrl+Enter)">
                <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" aria-hidden="true">
                    <line x1="22" y1="2" x2="11" y2="13"/>
                    <polygon points="22 2 15 22 11 13 2 9 22 2"/>
                </svg>
            </button>
        }
    </div>
</div>

@code {
    [Parameter] public bool Disabled { get; set; }
    [Parameter] public EventCallback<(string Text, List<AttachedImage> Images)> OnSubmit { get; set; }
    [Parameter] public EventCallback OnStop { get; set; }

    private string _text = "";
    private readonly List<AttachedImage> _attachedImages = [];
    private bool _isDragOver;

    private async Task HandleKeyDown(KeyboardEventArgs e)
    {
        if (e.Key == "Enter" && !e.ShiftKey)
            await Submit();
    }

    private async Task Submit()
    {
        var text = _text.Trim();
        if (string.IsNullOrEmpty(text)) return;
        var images = new List<AttachedImage>(_attachedImages);
        _text = "";
        _attachedImages.Clear();
        await OnSubmit.InvokeAsync((Text: text, Images: images));
    }

    private async Task HandleImageAttach(InputFileChangeEventArgs e)
    {
        foreach (var file in e.GetMultipleFiles(10))
        {
            if (file.Size > 10 * 1024 * 1024) continue;
            if (!file.ContentType.StartsWith("image/")) continue;
            using var ms = new MemoryStream();
            await file.OpenReadStream(10 * 1024 * 1024).CopyToAsync(ms);
            var b64 = Convert.ToBase64String(ms.ToArray());
            _attachedImages.Add(new AttachedImage($"data:{file.ContentType};base64,{b64}", file.ContentType));
        }
        StateHasChanged();
    }

    private void RemoveImage(int index) => _attachedImages.RemoveAt(index);

    private async Task HandleStop() => await OnStop.InvokeAsync();

    private void HandleDragOver(DragEventArgs e) => _isDragOver = true;
    private void HandleDragLeave(DragEventArgs e) => _isDragOver = false;

    private void HandleDrop(DragEventArgs e)
    {
        _isDragOver = false;
        // Blazor Server doesn't expose DataTransfer.Files in drop events;
        // image files must be attached via the InputFile button instead.
    }

    protected override void OnInitialized()
    {
        ColState.OnChange += HandleColStateChange;
    }

    private async void HandleColStateChange() => await InvokeAsync(StateHasChanged);

    public void Dispose() => ColState.OnChange -= HandleColStateChange;

    private async Task ConfirmClearChat()
    {
        var result = await DialogService.ShowMessageBox(
            "Clear Chat",
            "Are you sure you want to clear all chat messages? This action cannot be undone.",
            yesText: "Clear Chat",
            cancelText: "Cancel");

        if (result == true)
            ChatSt.Clear();
    }
}
